{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "OpenAdapt Desktop",
  "version": "0.1.1",
  "identifier": "ai.openadapt.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenAdapt Desktop",
        "width": 1120,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis", "deb", "appimage"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "externalBin": ["binaries/openadapt-engine"],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OpenAdaptAI/openadapt-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5MzM3MTQxNEJBRTJCNDYKUldSR0s2NUxRWEV6K2J6bXdxc2NYRVFqNkFFZUtrYUE4V1FqaTNVRktQU1RsSU9RR2RBWEcwVEgK"
    }
  }
}
